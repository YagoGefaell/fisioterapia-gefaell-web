---
import { Image } from "astro:assets";
import logo from "../assets/logo.png";

const navLinks = [
  { href: '#inicio', label: 'Inicio' },
  { href: '#servicios', label: 'Qué tratamos' },
  { href: '#clinica', label: 'Cómo trabaja' },
  { href: '#contacto', label: 'Contacto', variant: 'primary' },
];
---

<header
  class="sticky top-0 z-[100] border-b border-transparent bg-[linear-gradient(180deg,rgba(252,254,255,0.8),rgba(246,250,255,0.86))] backdrop-blur-[14px] transition-all duration-300"
  id="siteHeader"
>
  <nav class="site-container relative flex min-h-[74px] items-center justify-between px-6 py-[14px]">
    <a href="/" class="inline-flex items-center rounded-[10px] hover:opacity-100" aria-label="Volver al inicio">
      <Image
        src={logo}
        alt="Fisioterapia Gefaell"
        width={50}
        class="h-auto w-[112px] rounded-none sm:w-[50px]"
      />
    </a>
    <button
      class="flex cursor-pointer flex-col gap-[5px] border-none bg-transparent p-1 sm:hidden"
      id="menuToggle"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <span class="block h-[2px] w-6 rounded-[2px] bg-brand-700 transition-all duration-300"></span>
      <span class="block h-[2px] w-6 rounded-[2px] bg-brand-700 transition-all duration-300"></span>
      <span class="block h-[2px] w-6 rounded-[2px] bg-brand-700 transition-all duration-300"></span>
    </button>
    <ul
      class="absolute left-0 right-0 top-full z-50 hidden flex-col gap-2 border-b border-line bg-[#fafdff] p-4 shadow-[0_12px_26px_rgba(16,58,96,0.12)] sm:static sm:z-auto sm:flex sm:flex-row sm:items-center sm:gap-2 sm:border-0 sm:bg-transparent sm:p-0 sm:shadow-none"
      id="navLinks"
    >
      {navLinks.map(({ href, label, variant }) => (
        <li>
          <a
            href={href}
            class:list={[
              'block rounded-soft px-4 py-[10px] text-center text-[0.95rem] font-semibold text-brand-700 transition-all duration-300 hover:bg-[rgba(13,79,133,0.09)] hover:text-brand-700 hover:opacity-100 sm:px-[14px] sm:py-[9px] sm:text-left',
              variant === 'primary' &&
                'w-full rounded-card border border-brand-500 bg-[linear-gradient(135deg,#0d4f85,#0a365a)] px-[18px] py-[9px] text-white shadow-[0_10px_20px_rgba(13,79,133,0.24)] hover:border-brand-100 hover:bg-[linear-gradient(135deg,#e1f2ff,#d1e8fb)] hover:text-brand-700 hover:shadow-[0_14px_24px_rgba(13,79,133,0.14)] sm:w-auto',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<script>
    const toggle = document.getElementById('menuToggle')!;
    const links = document.getElementById('navLinks')!;
    const header = document.getElementById('siteHeader');

    const onScroll = () => {
      if (!header) return;
      const isScrolled = window.scrollY > 8;

      header.classList.toggle('border-line', isScrolled);
      header.classList.toggle('shadow-[0_10px_26px_rgba(13,49,82,0.14)]', isScrolled);
    };

    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });

    toggle.addEventListener('click', () => {
      const open = links.classList.contains('hidden');
      links.classList.toggle('hidden', !open);
      links.classList.toggle('flex', open);
      toggle.setAttribute('aria-expanded', String(open));
    })

    links.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        links.classList.add('hidden');
        links.classList.remove('flex');
        toggle.setAttribute('aria-expanded', 'false');
      });
    });
</script>