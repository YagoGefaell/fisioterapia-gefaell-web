---
import { Image } from "astro:assets";
import logo from "../assets/logo.png";

const navLinks = [
  { href: '#inicio', label: 'Inicio' },
  { href: '#servicios', label: 'Qué tratamos' },
  { href: '#clinica', label: 'Cómo trabaja' },
  { href: '#contacto', label: 'Contacto', variant: 'primary' },
];
---

<header class="header" id="siteHeader">
    <nav class="nav container">
        <a href="/" class="logo" aria-label="Volver al inicio">
          <Image src={logo} alt="Fisioterapia Gefaell" width={50} />
        </a>
        <button class="menu-toggle" id="menuToggle" aria-label="Toggle menu" aria-expanded="false">
            <span></span><span></span><span></span>
        </button>
        <ul class="nav-links" id="navLinks">
            {navLinks.map(({ href, label, variant }) => (
              <li><a href={href} class={variant ? `pill pill-${variant}` : ''}>{label}</a></li>
            ))}
        </ul>
    </nav>
</header>

<script>
    const toggle = document.getElementById('menuToggle')!;
    const links = document.getElementById('navLinks')!;
    const header = document.getElementById('siteHeader');

    const onScroll = () => {
      if (!header) return;
      header.classList.toggle('is-scrolled', window.scrollY > 8);
    };

    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });

    toggle.addEventListener('click', () => {
        const open = links.classList.toggle('open');
        toggle.setAttribute('aria-expanded', String(open));
    })

    links.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        links.classList.remove('open');
        toggle.setAttribute('aria-expanded', 'false');
      });
    });
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: linear-gradient(180deg, rgba(252, 254, 255, 0.8), rgba(246, 250, 255, 0.86));
    backdrop-filter: blur(14px);
    border-bottom: 1px solid transparent;
    transition: all var(--transition);
  }

  .header.is-scrolled {
    border-bottom-color: var(--color-border);
    box-shadow: 0 10px 26px rgba(13, 49, 82, 0.14);
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 24px;
    min-height: 74px;
  }

  .logo {
    display: inline-flex;
    align-items: center;
    border-radius: 10px;
  }

  .logo img {
    height: auto;
    border-radius: 0;
  }

  .logo:hover {
    opacity: 1;
  }

  .nav-links {
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .nav-links a {
    color: var(--color-primary-dark);
    font-size: 0.95rem;
    font-weight: 600;
    padding: 9px 14px;
    border-radius: var(--radius-sm);
    transition: all var(--transition);
  }

  .nav-links a:hover {
    background-color: rgba(13, 79, 133, 0.09);
    color: var(--color-primary-dark);
    opacity: 1;
  }

  .pill {
    border-radius: 999px;
    padding: 9px 18px;
    border: 1px solid transparent;
  }

  .nav-links a.pill-primary {
    background: linear-gradient(135deg, #0d4f85, #0a365a);
    color: #ffffff;
    border: 1px solid #0d4f85;
    box-shadow: 0 10px 20px rgba(13, 79, 133, 0.24);
  }

  .nav-links a.pill-primary:hover {
    background: linear-gradient(135deg, #0e568f, #0a365a);
    color: #ffffff;
    box-shadow: 0 14px 24px rgba(10, 54, 90, 0.28);
    transform: translateY(-2px);
    opacity: 1;
  }

  .menu-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .menu-toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background-color: var(--color-primary-dark);
    border-radius: 2px;
    transition: transform var(--transition), opacity var(--transition);
  }

  @media (max-width: 640px) {
    .logo img {
      width: 112px;
    }

    .menu-toggle {
      display: flex;
    }

    .nav-links {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      background: #fafdff;
      padding: 16px;
      border-bottom: 1px solid var(--color-border);
      gap: 8px;
      box-shadow: 0 12px 26px rgba(16, 58, 96, 0.12);
    }

    .nav-links.open {
      display: flex;
    }

    .nav-links a {
      display: block;
      padding: 10px 16px;
      text-align: center;
    }

    .pill {
      width: 100%;
    }
  }
</style>