---
const services = [
  {
    title: 'Fisioterapia musculoesquelética',
    description: 'Valoración clínica precisa y tratamiento personalizado para dolor cervical, lumbar, hombro y extremidades, combinando terapia manual y ejercicio terapéutico.',
  },
  {
    title: 'Osteopatía clínica',
    description: 'Abordaje global orientado a restaurar movilidad, reducir tensiones profundas y mejorar el equilibrio funcional entre estructuras musculoesqueléticas.',
  },
  {
    title: 'Pilates terapéutico',
    description: 'Sesiones guiadas para reforzar el core, optimizar la postura y prevenir recaídas con progresiones seguras adaptadas a tu nivel físico.',
  },
  {
    title: 'Rehabilitación postquirúrgica',
    description: 'Plan individualizado para recuperar movilidad, fuerza y control neuromuscular tras cirugía, respetando tiempos biológicos y objetivos funcionales.',
  },
  {
    title: 'Readaptación deportiva',
    description: 'Transición progresiva entre lesión y retorno al deporte con control de cargas, trabajo específico por gestos y prevención de nuevas lesiones.',
  },
  {
    title: 'Accidente de tráfico',
    description: 'Atención integral para latigazo cervical y secuelas asociadas, con seguimiento clínico riguroso y apoyo en la documentación del proceso.',
  },
];
---

<section id="servicios">
  <div class="container">
    <h2 class="section-title reveal">Servicios clínicos de alto nivel, adaptados a tu caso</h2>
    <p class="section-subtitle reveal">
      Tratamientos diseñados para resolver dolor, recuperar función y mantener resultados en el tiempo con una estrategia clínica clara.
    </p>

    <div class="services-grid">
      {services.map((service, index) => (
        <article class="service-card surface-card reveal" style={`transition-delay: ${index * 70}ms;`}>
          <span class="service-dot" aria-hidden="true"></span>
          <div class="service-copy">
            <h3>{service.title}</h3>
            <p>{service.description}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .service-card {
    position: relative;
    transition: all 0.3s ease;
    min-height: 190px;
    border-radius: 12px;
    overflow: hidden;
  }

  .service-dot {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, #138a9c, #0d4f85);
  }

  .service-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-hover);
  }

  .service-copy h3 {
    color: var(--color-primary-dark);
    margin-bottom: 10px;
    font-size: 1.08rem;
    font-weight: 600;
  }

  .service-copy p {
    color: var(--color-text-muted);
    font-size: 0.96rem;
    line-height: 1.62;
  }

  .service-copy {
    padding: 22px 20px 20px;
  }

  @media (max-width: 980px) {
    .services-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 768px) {
    .services-grid {
      grid-template-columns: 1fr;
      gap: 14px;
    }
  }
</style>
