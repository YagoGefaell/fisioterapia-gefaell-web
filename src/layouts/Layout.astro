---
interface Props {
  title: string;
  description?: string;
}

const { 
  title, 
  description = 'Fisioterapia y Osteopatía Gefaell Borrás en Vigo. Especialistas en rehabilitación, pilates terapéutico y bienestar integral.' 
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Poppins:wght@500;600;700&display=swap" rel="stylesheet">
    <title>{title} | Fisioterapia Gefaell Borrás</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --color-primary: #0d4f85;
    --color-primary-dark: #0a365a;
    --color-primary-light: #e6f2fb;
    --color-accent: #138a9c;
    --color-bg: #f3f7fb;
    --color-surface: #ffffff;
    --color-surface-soft: #f7fbff;

    --color-text: #132236;
    --color-text-muted: #526173;
    --color-border: #d2dfec;
    
    --font-heading: 'Poppins', system-ui, -apple-system, sans-serif;
    --font-body: 'Inter', system-ui, -apple-system, sans-serif;
    --max-width: 1160px;
    --radius: 12px;
    --radius-sm: 8px;
    --anchor-offset: 112px;
    --transition: 0.3s ease;
    --shadow-soft: 0 14px 30px rgba(13, 49, 82, 0.11);
    --shadow-hover: 0 24px 38px rgba(13, 49, 82, 0.17);
  }

  html {
    scroll-behavior: smooth;
    overflow-x: hidden;
  }

  body {
    font-family: var(--font-body);
    background:
      radial-gradient(circle at 8% 0%, rgba(13, 79, 133, 0.15), transparent 34%),
      radial-gradient(circle at 92% 96%, rgba(19, 138, 156, 0.14), transparent 38%),
      linear-gradient(155deg, rgba(255, 255, 255, 0.7), rgba(245, 250, 255, 0.8)),
      var(--color-bg);
    color: var(--color-text);
    line-height: 1.8;
    min-height: 100vh;
  }

  h1,
  h2,
  h3 {
    font-family: var(--font-heading);
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.01em;
  }

  p,
  a,
  button,
  li {
    font-family: var(--font-body);
  }

  a {
    color: var(--color-primary);
    text-decoration: none;
    transition: all var(--transition);
  }

  a:hover {
    opacity: 0.8;
  }

  img {
    display: block;
    max-width: 100%;
    border-radius: var(--radius-sm);
  }

  ul {
    list-style: none;
  }

  section {
    padding: 80px 24px;
  }

  main section[id] {
    scroll-margin-top: var(--anchor-offset);
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .surface-card {
    background: linear-gradient(155deg, #ffffff, var(--color-surface-soft));
    border-radius: var(--radius);
    box-shadow: var(--shadow-soft);
  }

  .section-title {
    font-size: clamp(2rem, 5vw, 2.8rem);
    font-weight: 600;
    margin-bottom: 16px;
    color: var(--color-primary);
    letter-spacing: -0.02em;
  }

  .section-subtitle {
    color: var(--color-text-muted);
    font-size: 1.15rem;
    margin-bottom: 56px;
    max-width: 600px;
  }

  .btn-primary {
    background-color: var(--color-primary);
    color: white;
    padding: 12px 28px;
    border-radius: var(--radius);
    font-weight: 600;
    display: inline-block;
    border: 1px solid transparent;
    box-shadow: 0 10px 20px rgba(13, 79, 133, 0.22);
    transition: all var(--transition);
  }

  .btn-primary:hover {
    background-color: var(--color-primary-dark);
    box-shadow: 0 16px 26px rgba(10, 54, 90, 0.28);
    transform: translateY(-2px);
    opacity: 1;
  }

  .btn-secondary {
    display: inline-block;
    padding: 12px 28px;
    border-radius: var(--radius);
    font-weight: 600;
    color: var(--color-primary-dark);
    background-color: #ffffff;
    border: 1px solid #b8cff2;
    transition: all var(--transition);
  }

  .btn-secondary:hover {
    background-color: var(--color-primary-light);
    box-shadow: 0 12px 22px rgba(13, 79, 133, 0.14);
    transform: translateY(-2px);
    opacity: 1;
  }

  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }

  .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }

    .reveal,
    .reveal.is-visible,
    .btn-primary,
    .btn-secondary,
    a,
    * {
      animation: none !important;
      transition: none !important;
      transform: none !important;
    }
  }

  .zigzag-block {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 72px;
  }

  .zigzag-block.reverse .img-placeholder,
  .zigzag-block.reverse .media-frame {
    order: 2;
  }

  .zigzag-block.reverse .copy {
    order: 1;
  }

  .img-placeholder {
    width: 100%;
    aspect-ratio: 4 / 5;
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
    background: linear-gradient(100deg, var(--color-surface), #ffffff, var(--color-surface));
    background-size: 220% 100%;
    animation: shimmer 2.2s linear infinite;
  }

  .img-placeholder.wide {
    aspect-ratio: 16 / 9;
  }

  @keyframes shimmer {
    0% {
      background-position: 200% 0;
    }
    100% {
      background-position: -20% 0;
    }
  }

  @media (max-width: 768px) {
    :root {
      --anchor-offset: 96px;
    }

    section {
      padding: 74px 20px;
    }

    .section-subtitle {
      margin-bottom: 40px;
      font-size: 1.03rem;
    }

    .zigzag-block {
      grid-template-columns: 1fr;
      gap: 28px;
    }

    .zigzag-block.reverse .img-placeholder,
    .zigzag-block.reverse .media-frame,
    .zigzag-block.reverse .copy {
      order: unset;
    }
  }
</style>